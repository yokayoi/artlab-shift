rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /schedules/{monthId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /availabilities/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
        request.resource.data.facilitatorId == request.auth.uid;
      allow write: if isAdmin();
    }

    match /shifts/{monthId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attendance/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.facilitatorId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.facilitatorId == request.auth.uid;
      allow write: if isAdmin();
    }

    match /announcements/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /payrollConfirmations/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /payrollCarryOvers/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /payrollAcknowledgments/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
        request.resource.data.facilitatorId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.facilitatorId == request.auth.uid || isAdmin()
      );
    }

    match /payrollReports/{reportId} {
      allow read: if isAuthenticated() && (
        resource.data.facilitatorId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.facilitatorId == request.auth.uid &&
        request.resource.data.status == "open";
      allow update, delete: if isAdmin();
    }

    match /calendarEvents/{monthId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ========== Newsletter App ==========
    function isNewsletterAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update, delete: if false;
    }

    match /subscribers/{docId} {
      allow read, write: if isNewsletterAdmin();
    }

    match /campaigns/{docId} {
      allow read, write: if isNewsletterAdmin();
    }

    match /templates/{docId} {
      allow read, write: if isNewsletterAdmin();
    }

    match /sendLogs/{docId} {
      allow read, write: if isNewsletterAdmin();
    }
  }
}
